# =============================================================================
# Brazilian Legislation Scraper - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# ---------------------
# LLM Configuration
# ---------------------
# Used by scrapers that need OCR/text extraction from images via an LLM.
LLM_API_KEY=your-api-key-here
LLM_MODEL=your-model-name
PROVIDER_BASE_URL=https://openrouter.ai/api/v1

# ---------------------
# Output Directories
# ---------------------
# Base directory where scraped legislation data is saved (JSON files grouped by year).
# Defaults to "outputs/legislation" if not set.
SAVE_DIR=/path/to/your/save/directory/

# Directory for state legislation document files (PDFs, etc.).
STATE_LEGISLATION_SAVE_DIR=/path/to/your/save/directory/LEGISLACAO_ESTADUAL

# Directory for specific legislation document files (CONAMA, ICMBio, etc.).
SPECIFIC_LEGISLATION_SAVE_DIR=/path/to/your/save/directory/LEGISLACAO_ESPECIFICA

# ---------------------
# Logging
# ---------------------
# Directory where per-scraper runtime logs and error logs are saved.
# Defaults to "logs/legislation" if not set.
LOG_DIR=logs/legislation
